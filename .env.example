# Required: Get your API key from https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional overrides (defaults shown)
CLAUDE_MODEL=claude-sonnet-4-6
DAYS_AHEAD=7
MAX_EMAIL_RESULTS=10
MAX_TOKENS=4096

# Path to the Google OAuth credentials JSON file downloaded from Google Cloud Console.
# Used by BOTH the Google Calendar MCP server (for calendar access) and
# the app itself (for Gmail access).
GOOGLE_CALENDAR_CREDENTIALS=credentials.json
CREDENTIALS_FILE=credentials.json

# Gmail token cache (auto-created on first run)
TOKEN_FILE=token.json
